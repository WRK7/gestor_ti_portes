# Servidor
PORT=3847
HOST=0.0.0.0
NODE_ENV=development

# Banco
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gestor_ti
DB_USER=root
DB_PASSWORD=

# JWT (obrigatório em produção: use valor longo e aleatório)
JWT_SECRET=altere_para_um_segredo_longo
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# CORS — origem exata do front (separar por vírgula). Obrigatório em produção com domínio fixo.
# Ex.: http://localhost:5173,http://10.100.20.137:5292,https://app.suaempresa.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rede local (10.x, 192.168.x, 172.16–31.x): em dev o back-end aceita essas origens automaticamente.
# Em produção (NODE_ENV=production), defina true para acessar o front por IP na LAN, ou liste tudo em CORS_ORIGINS.
# CORS_ALLOW_LAN=true

# Cookies (refresh HttpOnly)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true
REFRESH_COOKIE_NAME=refresh_token

# Opcional: invalidar todos os refresh tokens do usuário ao novo login
# REVOKE_REFRESH_ON_LOGIN=true

# Rate limit
RATE_LIMIT_MAX=1000
LOGIN_RATE_LIMIT_MAX=10
REFRESH_RATE_LIMIT_MAX=60

# Primeiro admin — use só com npm run bootstrap:admin
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# ADMIN_EMAIL=
# ADMIN_NAME=
# ADMIN_ROLE=superadmin
